# ----------------------------
# Fraud Transaction - Env File
# ----------------------------

# Connector app (FRAUD_TRANSACTION/app.py)
WEB1_URL=http://127.0.0.1:5000
WEB2_URL=http://127.0.0.1:8000
PORT=10000

# Web 1 Admin defaults (optional override)
WEB1_ADMIN_NAME=admin
WEB1_ADMIN_EMAIL=admin@fraudwatch.local
WEB1_ADMIN_PASSWORD=Admin@123

# Web 2 Admin defaults (optional override)
WEB2_ADMIN_NAME=admin
WEB2_ADMIN_EMAIL=admin@fraudwatch.local
WEB2_ADMIN_PASSWORD=Admin@123
WEB2_RESET_KEY=RESET@123

# Twilio (optional for SMS alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMTP (required for Web1 admin OTP email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
